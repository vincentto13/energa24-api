# Option 1: native Energa credentials (24.energa.pl)
ENERGA_USERNAME=user@example.com
ENERGA_PASSWORD=your-energa-password

# Option 2: OrlenID credentials (oid-ws.orlen.pl — shared across Orlen Group services)
# When set, these take priority over ENERGA_USERNAME / ENERGA_PASSWORD
# ORLENID_USERNAME=user@example.com
# ORLENID_PASSWORD=your-orlenid-password
